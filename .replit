modules = ["nodejs-20", "web", "postgresql-16", "python-3.11"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"

[env]
PORT = "5000"

[deployment]
deploymentTarget = "vm"
build = ["sh", "-c", "bash scripts/build.sh"]
publicDir = "dist/public"
run = ["sh", "-c", "PORT=5000 HOSTNAME=0.0.0.0 node scripts/wrapper.js"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/build-and-start.sh"
waitForPort = 5000

[agent]
stack = "MOCKUP_JS"
mockupState = "FULLSTACK"
integrations = [
  "javascript_object_storage:2.0.0",
  "javascript_openai_ai_integrations:2.0.0",
  "sendgrid:1.0.0",
]

[userenv]

[userenv.shared]
MASTER_ADMIN_PASSWORD_HASH = "$2b$10$n/tLg0U5w9nrJPL.MR5keeD7/W3evelVXf1J3NrmGurNRj90wiliG"
AI_DISABLED = "false"
AI_FEATURES_DISABLED = ""
ACTIVE_LLM_PROVIDER = "openai"

[userenv.development]
DEV_BYPASS_AUTH = "true"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 360000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001
