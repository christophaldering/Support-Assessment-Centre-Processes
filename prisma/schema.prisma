generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model HealthCheck {
  id        String   @id @default(uuid())
  status    String   @default("ok")
  checkedAt DateTime @default(now()) @map("checked_at")

  @@map("health_check")
}

model Workspace {
  id                 String   @id @default(uuid())
  slug               String   @unique
  name               String
  status             String   @default("active")
  adminPasswordHash  String   @map("admin_password_hash")
  dataResidency      String   @default("EU") @map("data_residency")
  createdAt          DateTime @default(now()) @map("created_at")

  theme              Theme?
  users              User[]
  assessments        Assessment[]

  @@map("workspaces")
}

model Theme {
  id                String @id @default(uuid())
  workspaceId       String @unique @map("workspace_id")
  primaryColor      String @map("primary_color")
  secondaryColor    String @map("secondary_color")
  accentColor       String @map("accent_color")
  backgroundColor   String @default("#ffffff") @map("background_color")
  textColor         String @default("#1a1a1a") @map("text_color")
  fontFamily        String @default("Inter") @map("font_family")
  fontFamilyHeading String @default("Playfair Display") @map("font_family_heading")
  logoUrl           String? @map("logo_url")

  workspace         Workspace @relation(fields: [workspaceId], references: [id])

  @@map("themes")
}

model User {
  id                  String   @id @default(uuid())
  email               String
  name                String
  passwordHash        String   @map("password_hash")
  roles               String[]
  workspaceId         String   @map("workspace_id")
  assessmentId        String?  @map("assessment_id")
  forcePasswordChange Boolean  @default(false) @map("force_password_change")
  status              String   @default("active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  workspace           Workspace @relation(fields: [workspaceId], references: [id])
  assessment          Assessment? @relation(fields: [assessmentId], references: [id])
  passwordResetTokens PasswordResetToken[]
  uploadedDocuments   Document[]

  @@unique([email, workspaceId])
  @@map("users")
}

model Assessment {
  id           String   @id @default(uuid())
  name         String
  workspaceId  String   @map("workspace_id")
  status       String   @default("draft")
  description  String?
  location     String?
  startDate    DateTime? @map("start_date")
  endDate      DateTime? @map("end_date")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  candidates   User[]
  exercises    Exercise[]
  documents    Document[]

  @@map("assessments")
}

model Exercise {
  id             String   @id @default(uuid())
  assessmentId   String   @map("assessment_id")
  name           String
  type           String
  instructions   String?
  duration       Int?
  sortOrder      Int      @default(0) @map("sort_order")
  status         String   @default("active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  assessment     Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  documents      Document[]

  @@map("exercises")
}

model Document {
  id             String   @id @default(uuid())
  assessmentId   String   @map("assessment_id")
  exerciseId     String?  @map("exercise_id")
  name           String
  fileName       String   @map("file_name")
  fileSize       Int      @map("file_size")
  mimeType       String   @map("mime_type")
  objectPath     String   @map("object_path")
  version        Int      @default(1)
  visibleTo      String[] @map("visible_to")
  watermark      Boolean  @default(false)
  uploadedById   String   @map("uploaded_by_id")
  createdAt      DateTime @default(now()) @map("created_at")

  assessment     Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  exercise       Exercise?  @relation(fields: [exerciseId], references: [id], onDelete: SetNull)
  uploadedBy     User       @relation(fields: [uploadedById], references: [id])

  @@map("documents")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user      User @relation(fields: [userId], references: [id])

  @@map("password_reset_tokens")
}
