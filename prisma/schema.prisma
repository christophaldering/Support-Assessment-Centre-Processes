generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model HealthCheck {
  id        String   @id @default(uuid())
  status    String   @default("ok")
  checkedAt DateTime @default(now()) @map("checked_at")

  @@map("health_check")
}

model Workspace {
  id                 String   @id @default(uuid())
  slug               String   @unique
  name               String
  status             String   @default("active")
  adminPasswordHash  String   @map("admin_password_hash")
  dataResidency      String   @default("EU") @map("data_residency")
  consolidationConfig Json?   @map("consolidation_config")
  aiEnabled          Boolean  @default(false) @map("ai_enabled")
  autonomousDiagMode Boolean  @default(false) @map("autonomous_diag_mode")
  featureFlags       Json?    @map("feature_flags")
  createdAt          DateTime @default(now()) @map("created_at")

  theme              Theme?
  users              User[]
  assessments        Assessment[]
  competencyModels   CompetencyModel[]
  scaleDefinitions   ScaleDefinition[]
  requirementsAnalyses RequirementsAnalysis[]
  auditLogs          AuditLog[]
  consentTemplates   ConsentTemplate[]
  consentRecords     ConsentRecord[]
  audioRecordings    AudioRecording[]
  reports            Report[]
  reportTemplates    ReportTemplate[]
  usageEvents        UsageEvent[]

  accessRequests     AccessRequest[]
  styleGuides        WorkspaceStyleGuide[]
  brandRuleSets      BrandRuleSet[]
  exerciseLibraryItems ExerciseLibraryItem[]
  exerciseRecommendations ExerciseRecommendation[]
  clients            Client[]
  predictiveProfiles PredictiveProfile[]
  developmentBlueprints DevelopmentBlueprint[]
  diagnosticHypotheses DiagnosticHypothesis[]
  observationSheetTemplates ObservationSheetTemplate[]
  caseStudies        CaseStudy[]

  @@map("workspaces")
}

model Client {
  id          String   @id @default(uuid())
  workspaceId String   @map("workspace_id")
  name        String
  industry    String?
  contactInfo String?  @map("contact_info")
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  assessments Assessment[]
  exerciseLibraryItems ExerciseLibraryItem[]

  @@index([workspaceId])
  @@map("clients")
}

model AccessRequest {
  id          String   @id @default(uuid())
  email       String
  name        String
  message     String?
  workspaceId String   @map("workspace_id")
  status      String   @default("pending")
  reviewedAt  DateTime? @map("reviewed_at")
  reviewedBy  String?  @map("reviewed_by")
  createdAt   DateTime @default(now()) @map("created_at")

  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([email, workspaceId])
  @@map("access_requests")
}

model Theme {
  id                String @id @default(uuid())
  workspaceId       String @unique @map("workspace_id")
  primaryColor      String @map("primary_color")
  secondaryColor    String @map("secondary_color")
  accentColor       String @map("accent_color")
  backgroundColor   String @default("#ffffff") @map("background_color")
  textColor         String @default("#1a1a1a") @map("text_color")
  fontFamily        String @default("Inter") @map("font_family")
  fontFamilyHeading String @default("Playfair Display") @map("font_family_heading")
  logoUrl           String? @map("logo_url")

  workspace         Workspace @relation(fields: [workspaceId], references: [id])

  @@map("themes")
}

model User {
  id                  String   @id @default(uuid())
  email               String
  name                String
  passwordHash        String   @map("password_hash")
  roles               String[]
  workspaceId         String   @map("workspace_id")
  assessmentId        String?  @map("assessment_id")
  forcePasswordChange Boolean  @default(false) @map("force_password_change")
  status              String   @default("active")
  observerType        String?  @map("observer_type")
  canExport           Boolean  @default(true) @map("can_export")
  accessCode          String?  @map("access_code")
  language            String   @default("de")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  workspace           Workspace @relation(fields: [workspaceId], references: [id])
  assessment          Assessment? @relation(fields: [assessmentId], references: [id])
  passwordResetTokens PasswordResetToken[]
  uploadedDocuments   Document[]

  @@unique([email, workspaceId])
  @@map("users")
}

model Assessment {
  id           String   @id @default(uuid())
  name         String
  workspaceId  String   @map("workspace_id")
  clientId     String?  @map("client_id")
  clientName   String?  @map("client_name")
  status       String   @default("draft")
  description  String?
  location     String?
  startDate    DateTime? @map("start_date")
  endDate      DateTime? @map("end_date")
  designMode   String   @default("classic") @map("design_mode")
  aiGenerated  Boolean  @default(false) @map("ai_generated")
  sourceAnalysisId String? @map("source_analysis_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")
  autoDeleteDays Int?     @map("auto_delete_days")
  processStep    Int      @default(0) @map("process_step")
  targetPosition String?  @map("target_position")
  workflowConfig Json?    @map("workflow_config")

  workspace          Workspace @relation(fields: [workspaceId], references: [id])
  client             Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  candidates         User[]
  exercises          Exercise[]
  documents          Document[]
  observerRatings    ObserverRating[]
  consolidatedScores ConsolidatedScore[]
  reports            Report[]
  observationSheets  ObservationSheet[]
  mtmmSnapshots      MtmmSnapshot[]
  portalDocuments    PortalDocument[]
  selfAssessments    SelfAssessment[]

  @@map("assessments")
}

model Exercise {
  id              String   @id @default(uuid())
  assessmentId    String   @map("assessment_id")
  name            String
  type            String
  instructions    String?
  duration        Int?
  sortOrder       Int      @default(0) @map("sort_order")
  status          String   @default("active")
  difficultyLevel String?  @map("difficulty_level")
  difficultyMeta  Json?    @map("difficulty_meta")
  aiGenerated     Boolean  @default(false) @map("ai_generated")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  assessment           Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  documents            Document[]
  competencyMappings   ExerciseCompetencyMapping[]
  observerRatings      ObserverRating[]

  @@map("exercises")
}

model Document {
  id             String   @id @default(uuid())
  assessmentId   String   @map("assessment_id")
  exerciseId     String?  @map("exercise_id")
  name           String
  fileName       String   @map("file_name")
  fileSize       Int      @map("file_size")
  mimeType       String   @map("mime_type")
  objectPath     String   @map("object_path")
  version        Int      @default(1)
  visibleTo      String[] @map("visible_to")
  watermark      Boolean  @default(false)
  uploadedById   String?  @map("uploaded_by_id")
  createdAt      DateTime @default(now()) @map("created_at")

  assessment     Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  exercise       Exercise?  @relation(fields: [exerciseId], references: [id], onDelete: SetNull)
  uploadedBy     User?      @relation(fields: [uploadedById], references: [id])

  @@map("documents")
}

model CompetencyModel {
  id             String   @id @default(uuid())
  workspaceId    String   @map("workspace_id")
  name           String
  description    String?
  companyName    String?  @map("company_name")
  modelYear      Int?     @map("model_year")
  version        Int      @default(1)
  status         String   @default("draft")
  sourceType     String   @default("manual") @map("source_type")
  sourceFileName String?  @map("source_file_name")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  nodes        CompetencyNode[]
  weightingProfiles WeightingProfile[]

  @@map("competency_models")
}

model CompetencyNode {
  id                String   @id @default(uuid())
  competencyModelId String   @map("competency_model_id")
  parentId          String?  @map("parent_id")
  name              String
  nodeType          String   @default("competency") @map("node_type")
  description       String?
  sortOrder         Int      @default(0) @map("sort_order")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")

  competencyModel   CompetencyModel @relation(fields: [competencyModelId], references: [id], onDelete: Cascade)
  parent            CompetencyNode? @relation("NodeHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children          CompetencyNode[] @relation("NodeHierarchy")
  exerciseMappings  ExerciseCompetencyMapping[]

  @@map("competency_nodes")
}

model ScaleDefinition {
  id           String   @id @default(uuid())
  workspaceId  String   @map("workspace_id")
  name         String
  type         String   @default("likert")
  minValue     Int?     @map("min_value")
  maxValue     Int?     @map("max_value")
  points       Json     @default("[]")
  status       String   @default("active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  workspace    Workspace @relation(fields: [workspaceId], references: [id])

  @@map("scale_definitions")
}

model WeightingProfile {
  id                String   @id @default(uuid())
  competencyModelId String   @map("competency_model_id")
  name              String
  targetRole        String?  @map("target_role")
  version           Int      @default(1)
  weights           Json     @default("[]")
  status            String   @default("active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")

  competencyModel   CompetencyModel @relation(fields: [competencyModelId], references: [id], onDelete: Cascade)

  @@map("weighting_profiles")
}

model MtmmSnapshot {
  id             String    @id @default(uuid())
  assessmentId   String    @map("assessment_id")
  version        Int       @default(1)
  label          String?
  status         String    @default("draft")
  lockedAt       DateTime? @map("locked_at")
  lockedReason   String?   @map("locked_reason")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at")

  assessment     Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  mappings       ExerciseCompetencyMapping[]

  @@index([assessmentId])
  @@map("mtmm_snapshots")
}

model ExerciseCompetencyMapping {
  id               String   @id @default(uuid())
  exerciseId       String   @map("exercise_id")
  competencyNodeId String   @map("competency_node_id")
  weight           Float    @default(1.0)
  snapshotId       String?  @map("snapshot_id")
  createdAt        DateTime @default(now()) @map("created_at")

  exercise         Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  competencyNode   CompetencyNode @relation(fields: [competencyNodeId], references: [id], onDelete: Cascade)
  snapshot         MtmmSnapshot? @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@unique([exerciseId, competencyNodeId, snapshotId])
  @@map("exercise_competency_mappings")
}

model RequirementsAnalysis {
  id              String   @id @default(uuid())
  workspaceId     String   @map("workspace_id")
  title           String
  clientName      String?  @map("client_name")
  projectName     String?  @map("project_name")
  mode            String   @default("auto")
  status          String   @default("pending")
  inputType       String   @map("input_type")
  objectPath      String?  @map("object_path")
  originalFileName String? @map("original_file_name")
  transcript      String?
  proposal        Json?
  consentGiven    Boolean  @default(false) @map("consent_given")
  consentTimestamp DateTime? @map("consent_timestamp")
  consentUserId   String?  @map("consent_user_id")
  appliedAssessmentId String? @map("applied_assessment_id")
  autoDeleteAt    DateTime? @map("auto_delete_at")
  createdById     String   @map("created_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  workspace       Workspace @relation(fields: [workspaceId], references: [id])

  @@map("requirements_analyses")
}

model AuditLog {
  id          String   @id @default(uuid())
  workspaceId String   @map("workspace_id")
  userId      String?  @map("user_id")
  action      String
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  details     Json?
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at")

  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user      User @relation(fields: [userId], references: [id])

  @@map("password_reset_tokens")
}

model ObserverRating {
  id               String   @id @default(uuid())
  assessmentId     String   @map("assessment_id")
  exerciseId       String   @map("exercise_id")
  competencyNodeId String   @map("competency_node_id")
  candidateId      String   @map("candidate_id")
  observerId       String   @map("observer_id")
  rating           Float?
  evidenceNotes    String?  @map("evidence_notes")
  evidenceStructured Json?  @map("evidence_structured")
  scaleId          String?  @map("scale_id")
  version          Int      @default(1)
  syncedAt         DateTime? @map("synced_at")
  clientTimestamp   DateTime? @map("client_timestamp")
  status           String   @default("draft")
  aiGenerated      Boolean  @default(false) @map("ai_generated")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  assessment       Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  exercise         Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, exerciseId, competencyNodeId, candidateId, observerId])
  @@index([assessmentId, candidateId])
  @@index([observerId])
  @@map("observer_ratings")
}

model ConsolidatedScore {
  id               String   @id @default(uuid())
  assessmentId     String   @map("assessment_id")
  candidateId      String   @map("candidate_id")
  competencyNodeId String   @map("competency_node_id")
  exerciseId       String?  @map("exercise_id")
  consolidatedValue Float   @map("consolidated_value")
  normalizedValue  Float?   @map("normalized_value")
  method           String   @default("mean")
  raterCount       Int      @default(0) @map("rater_count")
  variance         Float?
  outlierFlag      Boolean  @default(false) @map("outlier_flag")
  moderatorOverride Float?  @map("moderator_override")
  overrideReason   String?  @map("override_reason")
  algorithmMeta    Json?    @map("algorithm_meta")
  version          Int      @default(1)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  assessment       Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, candidateId, competencyNodeId, exerciseId])
  @@index([assessmentId, candidateId])
  @@map("consolidated_scores")
}

model ConsentTemplate {
  id           String   @id @default(uuid())
  workspaceId  String   @map("workspace_id")
  name         String
  language     String   @default("de")
  category     String   @default("general")
  content      String
  version      Int      @default(1)
  status       String   @default("active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  records      ConsentRecord[]

  @@index([workspaceId, category])
  @@map("consent_templates")
}

model ConsentRecord {
  id             String   @id @default(uuid())
  workspaceId    String   @map("workspace_id")
  templateId     String   @map("template_id")
  userId         String   @map("user_id")
  feature        String
  granted        Boolean  @default(false)
  grantedAt      DateTime? @map("granted_at")
  revokedAt      DateTime? @map("revoked_at")
  ipAddress      String?  @map("ip_address")
  createdAt      DateTime @default(now()) @map("created_at")

  workspace      Workspace @relation(fields: [workspaceId], references: [id])
  template       ConsentTemplate @relation(fields: [templateId], references: [id])

  @@index([workspaceId, userId, feature])
  @@map("consent_records")
}

model AudioRecording {
  id              String   @id @default(uuid())
  workspaceId     String   @map("workspace_id")
  assessmentId    String?  @map("assessment_id")
  exerciseId      String?  @map("exercise_id")
  candidateId     String?  @map("candidate_id")
  objectPath      String   @map("object_path")
  originalFileName String? @map("original_file_name")
  duration        Int?
  transcript      String?
  aiSummary       String?  @map("ai_summary")
  aiSummaryMeta   Json?    @map("ai_summary_meta")
  retentionDays   Int      @default(90) @map("retention_days")
  expiresAt       DateTime? @map("expires_at")
  status          String   @default("uploaded")
  createdById     String   @map("created_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  workspace       Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, assessmentId])
  @@map("audio_recordings")
}

model Report {
  id             String   @id @default(uuid())
  workspaceId    String   @map("workspace_id")
  assessmentId   String   @map("assessment_id")
  candidateId    String?  @map("candidate_id")
  title          String
  format         String   @default("pdf")
  objectPath     String?  @map("object_path")
  snapshotData   Json?    @map("snapshot_data")
  aiSections     String[] @map("ai_sections")
  version        Int      @default(1)
  status         String   @default("generating")
  generatedAt    DateTime? @map("generated_at")
  createdById    String   @map("created_by_id")
  createdAt      DateTime @default(now()) @map("created_at")

  workspace      Workspace @relation(fields: [workspaceId], references: [id])
  assessment     Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId, candidateId])
  @@map("reports")
}

model ReportTemplate {
  id                  String   @id @default(uuid())
  workspaceId         String   @map("workspace_id")
  name                String
  reportType          String   @map("report_type")
  sourceFilePath      String?  @map("source_file_path")
  sourceFileName      String?  @map("source_file_name")
  sourceFileSize      Int?     @map("source_file_size")
  anonymizedFilePath  String?  @map("anonymized_file_path")
  isAnonymized        Boolean  @default(false) @map("is_anonymized")
  structureJson       Json?    @map("structure_json")
  styleRulesJson      Json?    @map("style_rules_json")
  analysisStatus      String   @default("pending") @map("analysis_status")
  status              String   @default("draft")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  workspace           Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
  @@index([workspaceId, reportType])
  @@map("report_templates")
}

model UsageEvent {
  id           String   @id @default(uuid())
  workspaceId  String   @map("workspace_id")
  userId       String?  @map("user_id")
  eventType    String   @map("event_type")
  entityType   String?  @map("entity_type")
  entityId     String?  @map("entity_id")
  metadata     Json?
  credits      Float    @default(0)
  createdAt    DateTime @default(now()) @map("created_at")

  workspace    Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, eventType])
  @@index([workspaceId, createdAt])
  @@map("usage_events")
}

model WorkspaceStyleGuide {
  id              String   @id @default(uuid())
  workspaceId     String   @map("workspace_id")
  title           String
  sourceType      String   @map("source_type")
  fileObjectPath  String?  @map("file_object_path")
  rawTextExtract  String?  @map("raw_text_extract")
  analysisJson    Json?    @map("analysis_json")
  status          String   @default("uploaded")
  version         String   @default("1.0")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  workspace       Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
  @@map("workspace_style_guides")
}

model BrandRuleSet {
  id                      String   @id @default(uuid())
  workspaceId             String   @map("workspace_id")
  name                    String
  derivedFromStyleGuideIds String[] @map("derived_from_style_guide_ids")
  rulesJson               Json     @map("rules_json")
  appliesToWorkspaceUi    Boolean  @default(false) @map("applies_to_workspace_ui")
  appliesToDocuments      Boolean  @default(false) @map("applies_to_documents")
  appliesToPptExports     Boolean  @default(false) @map("applies_to_ppt_exports")
  appliesToExerciseMaterials Boolean @default(false) @map("applies_to_exercise_materials")
  status                  String   @default("draft")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  workspace               Workspace @relation(fields: [workspaceId], references: [id])
  exerciseVariants        ExerciseLibraryVariant[]

  @@index([workspaceId])
  @@map("brand_rule_sets")
}

model ExerciseLibraryItem {
  id                 String   @id @default(uuid())
  workspaceId        String   @map("workspace_id")
  clientId           String?  @map("client_id")
  clientName         String?  @map("client_name")
  projectName        String?  @map("project_name")
  title              String
  description        String?
  tags               String[]
  exerciseType       String   @map("exercise_type")
  scope              String   @default("general")
  scenarioId         String?  @map("scenario_id")
  targetLevels       String[] @map("target_levels")
  languagesAvailable String[] @map("languages_available")
  metadataJson       Json?    @map("metadata_json")
  qualityStatus      String   @default("draft") @map("quality_status")
  sourceProjectId    String?  @map("source_project_id")
  sourceContext      String?  @map("source_context")
  basedOnId          String?  @map("based_on_id")
  originalFileKey    String?  @map("original_file_key")
  originalFileName   String?  @map("original_file_name")
  originalFileSize   Int?     @map("original_file_size")
  originalMimeType   String?  @map("original_mime_type")
  downloadAllowed    Boolean  @default(true) @map("download_allowed")
  archivedAt         DateTime? @map("archived_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  workspace          Workspace @relation(fields: [workspaceId], references: [id])
  client             Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  scenario           CaseStudy? @relation(fields: [scenarioId], references: [id], onDelete: SetNull)
  variants           ExerciseLibraryVariant[]

  @@index([workspaceId])
  @@index([workspaceId, exerciseType])
  @@index([workspaceId, clientId])
  @@index([workspaceId, scope])
  @@index([scenarioId])
  @@map("exercise_library_items")
}

model ExerciseLibraryVariant {
  id              String   @id @default(uuid())
  libraryItemId   String   @map("library_item_id")
  variantType     String   @map("variant_type")
  brandRuleSetId  String?  @map("brand_rule_set_id")
  language        String   @default("DE")
  fileObjectPath  String?  @map("file_object_path")
  fileName        String?  @map("file_name")
  fileSize        Int?     @map("file_size")
  mimeType        String?  @map("mime_type")
  contentJson     Json?    @map("content_json")
  analysisJson    Json?    @map("analysis_json")
  version         String   @default("1.0")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  libraryItem     ExerciseLibraryItem @relation(fields: [libraryItemId], references: [id], onDelete: Cascade)
