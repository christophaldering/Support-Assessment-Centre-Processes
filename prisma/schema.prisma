generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model HealthCheck {
  id        String   @id @default(uuid())
  status    String   @default("ok")
  checkedAt DateTime @default(now()) @map("checked_at")

  @@map("health_check")
}

model Workspace {
  id                 String   @id @default(uuid())
  slug               String   @unique
  name               String
  status             String   @default("active")
  adminPasswordHash  String   @map("admin_password_hash")
  dataResidency      String   @default("EU") @map("data_residency")
  createdAt          DateTime @default(now()) @map("created_at")

  theme              Theme?
  users              User[]
  assessments        Assessment[]
  competencyModels   CompetencyModel[]
  scaleDefinitions   ScaleDefinition[]
  requirementsAnalyses RequirementsAnalysis[]
  auditLogs          AuditLog[]

  @@map("workspaces")
}

model Theme {
  id                String @id @default(uuid())
  workspaceId       String @unique @map("workspace_id")
  primaryColor      String @map("primary_color")
  secondaryColor    String @map("secondary_color")
  accentColor       String @map("accent_color")
  backgroundColor   String @default("#ffffff") @map("background_color")
  textColor         String @default("#1a1a1a") @map("text_color")
  fontFamily        String @default("Inter") @map("font_family")
  fontFamilyHeading String @default("Playfair Display") @map("font_family_heading")
  logoUrl           String? @map("logo_url")

  workspace         Workspace @relation(fields: [workspaceId], references: [id])

  @@map("themes")
}

model User {
  id                  String   @id @default(uuid())
  email               String
  name                String
  passwordHash        String   @map("password_hash")
  roles               String[]
  workspaceId         String   @map("workspace_id")
  assessmentId        String?  @map("assessment_id")
  forcePasswordChange Boolean  @default(false) @map("force_password_change")
  status              String   @default("active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  workspace           Workspace @relation(fields: [workspaceId], references: [id])
  assessment          Assessment? @relation(fields: [assessmentId], references: [id])
  passwordResetTokens PasswordResetToken[]
  uploadedDocuments   Document[]

  @@unique([email, workspaceId])
  @@map("users")
}

model Assessment {
  id           String   @id @default(uuid())
  name         String
  workspaceId  String   @map("workspace_id")
  status       String   @default("draft")
  description  String?
  location     String?
  startDate    DateTime? @map("start_date")
  endDate      DateTime? @map("end_date")
  aiGenerated  Boolean  @default(false) @map("ai_generated")
  sourceAnalysisId String? @map("source_analysis_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  candidates   User[]
  exercises    Exercise[]
  documents    Document[]

  @@map("assessments")
}

model Exercise {
  id              String   @id @default(uuid())
  assessmentId    String   @map("assessment_id")
  name            String
  type            String
  instructions    String?
  duration        Int?
  sortOrder       Int      @default(0) @map("sort_order")
  status          String   @default("active")
  difficultyLevel String?  @map("difficulty_level")
  difficultyMeta  Json?    @map("difficulty_meta")
  aiGenerated     Boolean  @default(false) @map("ai_generated")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  assessment           Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  documents            Document[]
  competencyMappings   ExerciseCompetencyMapping[]

  @@map("exercises")
}

model Document {
  id             String   @id @default(uuid())
  assessmentId   String   @map("assessment_id")
  exerciseId     String?  @map("exercise_id")
  name           String
  fileName       String   @map("file_name")
  fileSize       Int      @map("file_size")
  mimeType       String   @map("mime_type")
  objectPath     String   @map("object_path")
  version        Int      @default(1)
  visibleTo      String[] @map("visible_to")
  watermark      Boolean  @default(false)
  uploadedById   String   @map("uploaded_by_id")
  createdAt      DateTime @default(now()) @map("created_at")

  assessment     Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  exercise       Exercise?  @relation(fields: [exerciseId], references: [id], onDelete: SetNull)
  uploadedBy     User       @relation(fields: [uploadedById], references: [id])

  @@map("documents")
}

model CompetencyModel {
  id           String   @id @default(uuid())
  workspaceId  String   @map("workspace_id")
  name         String
  description  String?
  version      Int      @default(1)
  status       String   @default("draft")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  nodes        CompetencyNode[]
  weightingProfiles WeightingProfile[]

  @@map("competency_models")
}

model CompetencyNode {
  id                String   @id @default(uuid())
  competencyModelId String   @map("competency_model_id")
  parentId          String?  @map("parent_id")
  name              String
  nodeType          String   @default("competency") @map("node_type")
  description       String?
  sortOrder         Int      @default(0) @map("sort_order")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")

  competencyModel   CompetencyModel @relation(fields: [competencyModelId], references: [id], onDelete: Cascade)
  parent            CompetencyNode? @relation("NodeHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children          CompetencyNode[] @relation("NodeHierarchy")
  exerciseMappings  ExerciseCompetencyMapping[]

  @@map("competency_nodes")
}

model ScaleDefinition {
  id           String   @id @default(uuid())
  workspaceId  String   @map("workspace_id")
  name         String
  type         String   @default("likert")
  minValue     Int?     @map("min_value")
  maxValue     Int?     @map("max_value")
  points       Json     @default("[]")
  status       String   @default("active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  workspace    Workspace @relation(fields: [workspaceId], references: [id])

  @@map("scale_definitions")
}

model WeightingProfile {
  id                String   @id @default(uuid())
  competencyModelId String   @map("competency_model_id")
  name              String
  targetRole        String?  @map("target_role")
  version           Int      @default(1)
  weights           Json     @default("[]")
  status            String   @default("active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")

  competencyModel   CompetencyModel @relation(fields: [competencyModelId], references: [id], onDelete: Cascade)

  @@map("weighting_profiles")
}

model ExerciseCompetencyMapping {
  id               String   @id @default(uuid())
  exerciseId       String   @map("exercise_id")
  competencyNodeId String   @map("competency_node_id")
  weight           Float    @default(1.0)
  createdAt        DateTime @default(now()) @map("created_at")

  exercise         Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  competencyNode   CompetencyNode @relation(fields: [competencyNodeId], references: [id], onDelete: Cascade)

  @@unique([exerciseId, competencyNodeId])
  @@map("exercise_competency_mappings")
}

model RequirementsAnalysis {
  id              String   @id @default(uuid())
  workspaceId     String   @map("workspace_id")
  title           String
  mode            String   @default("auto")
  status          String   @default("pending")
  inputType       String   @map("input_type")
  objectPath      String?  @map("object_path")
  originalFileName String? @map("original_file_name")
  transcript      String?
  proposal        Json?
  consentGiven    Boolean  @default(false) @map("consent_given")
  consentTimestamp DateTime? @map("consent_timestamp")
  consentUserId   String?  @map("consent_user_id")
  appliedAssessmentId String? @map("applied_assessment_id")
  createdById     String   @map("created_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  workspace       Workspace @relation(fields: [workspaceId], references: [id])

  @@map("requirements_analyses")
}

model AuditLog {
  id          String   @id @default(uuid())
  workspaceId String   @map("workspace_id")
  userId      String?  @map("user_id")
  action      String
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  details     Json?
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at")

  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user      User @relation(fields: [userId], references: [id])

  @@map("password_reset_tokens")
}
