generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model HealthCheck {
  id        String   @id @default(uuid())
  status    String   @default("ok")
  checkedAt DateTime @default(now()) @map("checked_at")

  @@map("health_check")
}
